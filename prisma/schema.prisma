generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CARSFormSubmission {
  id String @id @default(uuid())

  personalRelationshipsScore        Float
  personalRelationshipsObservations String?
  imitationScore                    Float
  imitationObservations             String?
  emotionalResponseScore            Float
  emotionalResponseObservations     String?
  bodyUseScore                      Float
  bodyUseObservations               String?
  objectUseScore                    Float
  objectUseObservations             String?
  responseToChangeScore             Float
  responseToChangeObservations      String?
  visualResponseScore               Float
  visualResponseObservations        String?
  auditoryResponseScore             Float
  auditoryResponseObservations      String?
  tasteSmelLTouchScore              Float
  tasteSmelLTouchObservations       String?
  fearOrNervousnessScore            Float
  fearOrNervousnessObservations     String?
  verbalCommunicationScore          Float
  verbalCommunicationObservations   String?
  nonVerbalCommunicationScore       Float
  nonVerbalCommunicationObservations String?
  activityLevelScore                Float
  activityLevelObservations         String?
  intellectualResponseScore         Float
  intellectualResponseObservations  String?
  generalImpressionsScore           Float
  generalImpressionsObservations    String?

  totalScore Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("cars_form_submissions")
}
